{
  "name": "claude-code",
  "match": { "field": "hook_event_name", "exists": true },
  "switch": "hook_event_name",
  "cases": {
    "SessionStart": {
      "title": "{{basename cwd}}",
      "body": "started",
      "priority": "low",
      "source": "claude-code",
      "icon": "claude",
      "actions": [
        { "type": "focus-pid", "pid": "{{claude_pid}}", "label": "Open terminal" }
      ],
      "context": { "cwd": "{{cwd}}", "session_id": "{{session_id}}" }
    },
    "Notification": {
      "title": "{{basename cwd}}",
      "body": "{{message | default 'needs your input'}}",
      "priority": "urgent",
      "source": "claude-code",
      "icon": "claude",
      "actions": [
        { "type": "focus-pid", "pid": "{{claude_pid}}", "label": "Open terminal" }
      ],
      "context": { "cwd": "{{cwd}}", "session_id": "{{session_id}}" },
      "skip_if": { "field": "message", "matches": ["waiting for your input", "needs your permission"] }
    },
    "Stop": {
      "title": "{{basename cwd}}",
      "body": "{{note | default 'finished'}}",
      "priority": "normal",
      "source": "claude-code",
      "icon": "claude",
      "actions": [
        { "type": "focus-pid", "pid": "{{claude_pid}}", "label": "Open terminal" }
      ],
      "context": { "cwd": "{{cwd}}", "session_id": "{{session_id}}" }
    }
  }
}
