{
  "name": "github-actions",
  "match": { "field": "workflow_run", "exists": true },
  "switch": "workflow_run.conclusion",
  "cases": {
    "success": {
      "title":    "{{trim workflow_run.head_branch}}",
      "body":     "{{workflow_run.name | default 'CI'}} passed",
      "priority": "normal",
      "source":   "github-actions",
      "icon":     "success",
      "actions":  [
        { "type": "open-url", "url": "{{workflow_run.html_url}}", "label": "View run" }
      ]
    },
    "failure": {
      "title":    "{{trim workflow_run.head_branch}}",
      "body":     "{{workflow_run.name | default 'CI'}} failed",
      "priority": "urgent",
      "source":   "github-actions",
      "icon":     "error",
      "actions":  [
        { "type": "open-url", "url": "{{workflow_run.html_url}}", "label": "View run" }
      ]
    }
  }
}
