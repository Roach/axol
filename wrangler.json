{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "neuromast",
  "compatibility_date": "2025-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": { "enabled": true },
  "kv_namespaces": [
    {
      "binding": "QUEUE",
      "id": "REPLACE_WITH_KV_ID"
    },
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_KV_ID"
    }
  ]
}
